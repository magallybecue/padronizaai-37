{
  "name": "catmat-align-backend",
  "version": "1.0.0",
  "description": "Backend API para alinhamento de materiais CATMAT",
  "main": "index.js",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3001",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "sync:catmat": "tsx scripts/sync-catmat.ts",
    "sync:schedule": "node-cron '0 2 * * *' 'npm run sync:catmat'",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "@supabase/supabase-js": "^2.38.5",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.0.0",
    "date-fns": "^3.0.6",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.0.0",
    "jose": "^5.1.3",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.4",
    "next": "^14.0.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "papaparse": "^5.3.14",
    "string-similarity": "^4.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.3.14",
    "@types/react": "19.1.9",
    "@types/string-similarity": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^6.14.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "catmat",
    "materiais",
    "padronização",
    "compras-gov",
    "api"
  ],
  "author": "Catmat Align Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
